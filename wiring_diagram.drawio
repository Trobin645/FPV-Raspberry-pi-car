<mxfile host="app.diagrams.net" modified="2026-04-05T00:00:00.000Z" agent="Claude" version="21.0.0">
  <diagram name="FPV Robot Car Wiring" id="wiring-diagram">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TITLE -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="title" value="FPV Robot Car — Full Wiring Diagram" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="700" height="40" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- LIPO BATTERY -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="battery" value="&lt;b&gt;LIPO BATTERY&lt;/b&gt;&lt;br&gt;3S 11.1V&lt;br&gt;XT60 Female Connector" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="160" height="80" as="geometry" />
        </mxCell>
        <!-- Battery + terminal -->
        <mxCell id="bat_pos" value="+" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff0000;strokeColor=#AE4132;fontColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="190" width="30" height="30" as="geometry" />
        </mxCell>
        <!-- Battery - terminal -->
        <mxCell id="bat_neg" value="-" style="ellipse;whiteSpace=wrap;html=1;fillColor=#666666;strokeColor=#333333;fontColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="210" y="190" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- POWER SWITCH -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="switch" value="&lt;b&gt;POWER SWITCH&lt;/b&gt;&lt;br&gt;Toggle / Rocker&lt;br&gt;Rated 15A+" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="100" width="160" height="80" as="geometry" />
        </mxCell>
        <!-- Switch IN terminal -->
        <mxCell id="sw_in" value="IN" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff0000;strokeColor=#AE4132;fontColor=#ffffff;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="335" y="190" width="35" height="30" as="geometry" />
        </mxCell>
        <!-- Switch OUT terminal -->
        <mxCell id="sw_out" value="OUT" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff0000;strokeColor=#AE4132;fontColor=#ffffff;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="190" width="35" height="30" as="geometry" />
        </mxCell>

        <!-- Battery + to Switch IN (RED wire) -->
        <mxCell id="w_bat_sw" value="RED&#xa;12V+" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#ff0000;strokeWidth=3;fontColor=#ff0000;fontSize=9;fontStyle=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="bat_pos" target="sw_in" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Battery - GND bus label -->
        <mxCell id="gnd_label" value="GND BUS (shared negative — connects to Buck IN-, L298N GND, Pi GND)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="300" y="310" width="500" height="30" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- BUCK CONVERTER -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="buck" value="&lt;b&gt;BUCK CONVERTER&lt;/b&gt;&lt;br&gt;LM2596 / XL4016&lt;br&gt;IN: 11.1V → OUT: 5.1V&lt;br&gt;&lt;i&gt;Set to 5.1V BEFORE&lt;br&gt;connecting to Pi&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="160" height="110" as="geometry" />
        </mxCell>
        <!-- Buck IN+ -->
        <mxCell id="buck_in_pos" value="IN+" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff0000;strokeColor=#AE4132;fontColor=#ffffff;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="90" y="380" width="35" height="25" as="geometry" />
        </mxCell>
        <!-- Buck IN- -->
        <mxCell id="buck_in_neg" value="IN-" style="ellipse;whiteSpace=wrap;html=1;fillColor=#666666;strokeColor=#333333;fontColor=#ffffff;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="155" y="380" width="35" height="25" as="geometry" />
        </mxCell>
        <!-- Buck OUT+ -->
        <mxCell id="buck_out_pos" value="OUT+" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ff0000;strokeColor=#AE4132;fontColor=#ffffff;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="90" y="515" width="35" height="25" as="geometry" />
        </mxCell>
        <!-- Buck OUT- -->
        <mxCell id="buck_out_neg" value="OUT-" style="ellipse;whiteSpace=wrap;html=1;fillColor=#666666;strokeColor=#333333;fontColor=#ffffff;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="155" y="515" width="35" height="25" as="geometry" />
        </mxCell>

        <!-- Switch OUT to Buck IN+ (RED) -->
        <mxCell id="w_sw_buck" value="RED 12V+" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#ff0000;strokeWidth=3;fontColor=#ff0000;fontSize=9;fontStyle=1;" edge="1" source="sw_out" target="buck_in_pos" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="447" y="360" />
              <mxPoint x="107" y="360" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Battery - to Buck IN- (BLACK) -->
        <mxCell id="w_bat_buck_gnd" value="BLACK GND" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#666666;strokeWidth=3;fontColor=#666666;fontSize=9;fontStyle=1;" edge="1" source="bat_neg" target="buck_in_neg" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="225" y="340" />
              <mxPoint x="172" y="340" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- USB-C PIGTAIL -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="usbc" value="&lt;b&gt;USB-C PIGTAIL&lt;/b&gt;&lt;br&gt;Cut open — use 5V&lt;br&gt;and GND wires only&lt;br&gt;Plug into Pi USB-C port" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="620" width="160" height="90" as="geometry" />
        </mxCell>

        <!-- Buck OUT+ to USB-C 5V (RED) -->
        <mxCell id="w_buck_usbc_pos" value="RED 5.1V" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#ff0000;strokeWidth=2;fontColor=#ff0000;fontSize=9;fontStyle=1;" edge="1" source="buck_out_pos" target="usbc" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Buck OUT- to USB-C GND (BLACK) -->
        <mxCell id="w_buck_usbc_neg" value="BLACK GND" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#666666;strokeWidth=2;fontColor=#666666;fontSize=9;fontStyle=1;" edge="1" source="buck_out_neg" target="usbc" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- RASPBERRY PI 4 -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="pi" value="&lt;b&gt;RASPBERRY PI 4&lt;/b&gt;&lt;br&gt;─────────────────&lt;br&gt;GPIO 12 → ENA (PWM)&lt;br&gt;GPIO 13 → ENB (PWM)&lt;br&gt;GPIO 17 → IN1&lt;br&gt;GPIO 23 → IN2&lt;br&gt;GPIO 27 → IN3&lt;br&gt;GPIO 22 → IN4&lt;br&gt;GND → L298N GND&lt;br&gt;─────────────────&lt;br&gt;CSI Port → Camera" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="320" y="480" width="200" height="230" as="geometry" />
        </mxCell>

        <!-- USB-C to Pi -->
        <mxCell id="w_usbc_pi" value="USB-C 5.1V Power" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#ff0000;strokeWidth=2;fontColor=#ff0000;fontSize=9;fontStyle=1;dashed=1;" edge="1" source="usbc" target="pi" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- L298N MOTOR DRIVER -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="l298n" value="&lt;b&gt;L298N MOTOR DRIVER&lt;/b&gt;&lt;br&gt;──────────────────────&lt;br&gt;ENA ← GPIO 12 (PWM)&lt;br&gt;ENB ← GPIO 13 (PWM)&lt;br&gt;IN1 ← GPIO 17&lt;br&gt;IN2 ← GPIO 23&lt;br&gt;IN3 ← GPIO 27&lt;br&gt;IN4 ← GPIO 22&lt;br&gt;GND ← Pi GND&lt;br&gt;12V ← Battery via Switch&lt;br&gt;──────────────────────&lt;br&gt;OUT-A1, OUT-A2 → Left Motors&lt;br&gt;OUT-B1, OUT-B2 → Right Motors" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="650" y="400" width="240" height="290" as="geometry" />
        </mxCell>

        <!-- Pi GPIO to L298N (YELLOW wire — PWM) -->
        <mxCell id="w_pi_l298n_pwm" value="GPIO 12/13&#xa;PWM Enable&#xa;YELLOW" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;strokeWidth=2;fontColor=#b8860b;fontSize=9;fontStyle=1;" edge="1" source="pi" target="l298n" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="520" y="510" />
              <mxPoint x="650" y="510" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Pi GPIO to L298N (ORANGE wire — direction) -->
        <mxCell id="w_pi_l298n_dir" value="GPIO 17/23/27/22&#xa;Direction Pins&#xa;ORANGE" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d79b00;strokeWidth=2;fontColor=#d79b00;fontSize=9;fontStyle=1;" edge="1" source="pi" target="l298n" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="520" y="560" />
              <mxPoint x="650" y="560" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Pi GND to L298N GND (BLACK) -->
        <mxCell id="w_pi_l298n_gnd" value="GND&#xa;BLACK" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#666666;strokeWidth=2;fontColor=#666666;fontSize=9;fontStyle=1;" edge="1" source="pi" target="l298n" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="520" y="610" />
              <mxPoint x="650" y="610" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Switch OUT to L298N 12V (RED) -->
        <mxCell id="w_sw_l298n_12v" value="RED 12V+ direct from switch" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#ff0000;strokeWidth=3;fontColor=#ff0000;fontSize=9;fontStyle=1;" edge="1" source="sw_out" target="l298n" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="600" y="205" />
              <mxPoint x="770" y="205" />
              <mxPoint x="770" y="400" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Battery - to L298N GND (BLACK) -->
        <mxCell id="w_bat_l298n_gnd" value="BLACK GND" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#666666;strokeWidth=3;fontColor=#666666;fontSize=9;fontStyle=1;" edge="1" source="bat_neg" target="l298n" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="225" y="280" />
              <mxPoint x="850" y="280" />
              <mxPoint x="850" y="400" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- LEFT MOTORS -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="left_motors" value="&lt;b&gt;LEFT MOTORS&lt;/b&gt;&lt;br&gt;x2 DC Motors&lt;br&gt;wired in parallel&lt;br&gt;(+ to +, - to -)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1010" y="380" width="160" height="100" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- RIGHT MOTORS -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="right_motors" value="&lt;b&gt;RIGHT MOTORS&lt;/b&gt;&lt;br&gt;x2 DC Motors&lt;br&gt;wired in parallel&lt;br&gt;(+ to +, - to -)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1010" y="560" width="160" height="100" as="geometry" />
        </mxCell>

        <!-- L298N OUT-A to Left Motors (GREEN) -->
        <mxCell id="w_l298n_left" value="OUT-A1 / OUT-A2&#xa;GREEN wires" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#00cc00;strokeWidth=3;fontColor=#007700;fontSize=9;fontStyle=1;" edge="1" source="l298n" target="left_motors" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="990" y="450" />
              <mxPoint x="1010" y="450" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- L298N OUT-B to Right Motors (GREEN) -->
        <mxCell id="w_l298n_right" value="OUT-B1 / OUT-B2&#xa;GREEN wires" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#00cc00;strokeWidth=3;fontColor=#007700;fontSize=9;fontStyle=1;" edge="1" source="l298n" target="right_motors" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="990" y="590" />
              <mxPoint x="1010" y="590" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- CAMERA -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="camera" value="&lt;b&gt;IMX219 CAMERA&lt;/b&gt;&lt;br&gt;CSI Ribbon Cable&lt;br&gt;Blue side faces USB-A ports&lt;br&gt;on the Raspberry Pi" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="760" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- Pi to Camera (BLUE dashed — ribbon) -->
        <mxCell id="w_pi_cam" value="CSI Ribbon Cable" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#0066cc;strokeWidth=2;fontColor=#0066cc;fontSize=9;fontStyle=3;dashed=1;" edge="1" source="pi" target="camera" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- LEGEND BOX -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="legend" value="&lt;b&gt;WIRE COLOUR LEGEND&lt;/b&gt;&lt;br&gt;─────────────────────&lt;br&gt;&lt;font color=&#39;#ff0000&#39;&gt;RED — 12V Positive / 5V Power&lt;/font&gt;&lt;br&gt;&lt;font color=&#39;#666666&#39;&gt;BLACK — Ground / Negative&lt;/font&gt;&lt;br&gt;&lt;font color=&#39;#d6b656&#39;&gt;YELLOW — PWM Enable (ENA/ENB)&lt;/font&gt;&lt;br&gt;&lt;font color=&#39;#d79b00&#39;&gt;ORANGE — Direction (IN1-IN4)&lt;/font&gt;&lt;br&gt;&lt;font color=&#39;#00cc00&#39;&gt;GREEN — Motor Output (OUT-A/B)&lt;/font&gt;&lt;br&gt;&lt;font color=&#39;#0066cc&#39;&gt;BLUE (dashed) — CSI Ribbon&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="760" width="220" height="170" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- NOTES BOX -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="notes" value="&lt;b&gt;IMPORTANT NOTES&lt;/b&gt;&lt;br&gt;────────────────────────────&lt;br&gt;1. Set buck converter to 5.1V BEFORE&lt;br&gt;   connecting to Raspberry Pi&lt;br&gt;2. Pi and L298N must share GND&lt;br&gt;3. Never unplug XT60 while switch is ON&lt;br&gt;4. Cap motors at 70% PWM (see app.py)&lt;br&gt;5. If motors go wrong direction, swap&lt;br&gt;   forward/backward pins in app.py&lt;br&gt;6. Motors on same side wired in parallel&lt;br&gt;   (join + to + and - to - before L298N)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="650" y="760" width="300" height="180" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- XT60 NOTE -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="xt60_note" value="&lt;b&gt;XT60 BATTERY CONNECTOR&lt;/b&gt;&lt;br&gt;Cut male end off XT60 extension cable.&lt;br&gt;Strip wires. Connect RED to switch IN,&lt;br&gt;BLACK to GND bus. Plug battery female&lt;br&gt;socket in to connect/disconnect quickly." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="320" y="880" width="260" height="100" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
